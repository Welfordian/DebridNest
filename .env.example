# Required: API token for Real-Debrid-compatible auth (Authorization: Bearer)
DEBRIDNEST_API_TOKEN=change-me-to-a-long-random-string

# Public URL used in download/unrestrict links (must be reachable by Stremio clients)
DEBRIDNEST_PUBLIC_URL=http://localhost:8080

# Domain for Caddy TLS profile (docker compose --profile tls)
DEBRIDNEST_DOMAIN=localhost

# Cloudflare Tunnel token (docker compose --profile tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Jackett (included in docker compose --profile stremio)
# Internal URL for the Stremio addon container; use http://localhost:9117 only for the Jackett web UI
JACKETT_URL=http://jackett:9117
# Leave empty to auto-read from Jackett container on first boot (Docker)
JACKETT_API_KEY=
# Public indexers added automatically by jackett-setup on first boot
JACKETT_INDEXERS=limetorrents,therarbg,eztv,knaben,magnetz

# Data directory inside container (mapped to volume)
DEBRIDNEST_DATA_DIR=/data

# HTTP listen address for API
DEBRIDNEST_LISTEN=:8080

# Torrent client listen port (peer connections)
DEBRIDNEST_TORRENT_PORT=42069

# HMAC secret for signed download URLs (defaults to DEBRIDNEST_API_TOKEN if unset)
DEBRIDNEST_LINK_SECRET=

# Auto-select largest video file after this many seconds if no selectFiles call
DEBRIDNEST_AUTO_SELECT_SECONDS=5

# Signed download link TTL
DEBRIDNEST_LINK_TTL_HOURS=12

# Retention and quotas (see docs/operations.md)
DEBRIDNEST_RETENTION_DAYS=30
DEBRIDNEST_DISK_QUOTA_GB=0
# Minimum buffered data (MB) before streaming links are issued while torrent is still downloading
DEBRIDNEST_MIN_STREAM_MB=8
# How far ahead (MB) to prefetch when streaming from the start
DEBRIDNEST_STREAM_READAHEAD_MB=32
# Larger readahead (MB) when seeking/scrubbing to a new position
DEBRIDNEST_SEEK_READAHEAD_MB=64
# How far before the seek position (MB) to prefetch for container/keyframe headers
DEBRIDNEST_SEEK_PREROLL_MB=8
DEBRIDNEST_DOWNLOAD_RATE_LIMIT_MBPS=0
