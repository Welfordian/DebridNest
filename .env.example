# Required: API token for Real-Debrid-compatible auth (Authorization: Bearer).
# Replace this placeholder with a long random value before starting DebridNest.
DEBRIDNEST_API_TOKEN=change-me-to-a-long-random-string

# Multi-user auth (1 = per-user tokens in SQLite; 0 = legacy single shared token)
DEBRIDNEST_MULTI_USER=1

# Public URL used in download/unrestrict links (must be reachable by Stremio clients)
DEBRIDNEST_PUBLIC_URL=http://localhost:8080

# Domain for Caddy TLS profile (docker compose --profile tls)
DEBRIDNEST_DOMAIN=localhost

# Cloudflare Tunnel token (docker compose --profile tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Jackett (included in docker compose --profile stremio)
# Internal URL for the Stremio addon container; use http://localhost:9117 only for the Jackett web UI
JACKETT_URL=http://jackett:9117
# Leave empty to auto-read from Jackett container on first boot (Docker)
JACKETT_API_KEY=
# Public indexers added automatically by jackett-setup on first boot
JACKETT_INDEXERS=limetorrents,therarbg,eztv,knaben,magnetz

# Data directory inside container (mapped to volume)
DEBRIDNEST_DATA_DIR=/data

# HTTP listen address for API
DEBRIDNEST_LISTEN=:8080

# Torrent client listen port (peer connections)
DEBRIDNEST_TORRENT_PORT=42069

# HMAC secret for signed download URLs (defaults to DEBRIDNEST_API_TOKEN if unset)
DEBRIDNEST_LINK_SECRET=

# Auto-select largest video file after this many seconds if no selectFiles call
DEBRIDNEST_AUTO_SELECT_SECONDS=5

# Signed download link TTL (hours, must be greater than 0)
DEBRIDNEST_LINK_TTL_HOURS=12

# Retention and quotas (see docs/operations.md; 0 disables retention/quota/rate limits)
DEBRIDNEST_RETENTION_DAYS=30
DEBRIDNEST_DISK_QUOTA_GB=0
# Minimum buffered data (MB) before streaming links are issued while torrent is still downloading
DEBRIDNEST_MIN_STREAM_MB=8
# How far ahead (MB) to prefetch when streaming from the start
DEBRIDNEST_STREAM_READAHEAD_MB=32
# Larger readahead (MB) when seeking/scrubbing to a new position
DEBRIDNEST_SEEK_READAHEAD_MB=64
# How far before the seek position (MB) to prefetch for container/keyframe headers
DEBRIDNEST_SEEK_PREROLL_MB=8
DEBRIDNEST_DOWNLOAD_RATE_LIMIT_MBPS=0

# S3-compatible object storage (optional) — see docs/operations.md
# DEBRIDNEST_S3_ENABLED=0
# DEBRIDNEST_S3_ENDPOINT=https://…
# DEBRIDNEST_S3_BUCKET=
# DEBRIDNEST_S3_REGION=auto
# DEBRIDNEST_S3_ACCESS_KEY=
# DEBRIDNEST_S3_SECRET_KEY=
# DEBRIDNEST_S3_PREFIX=debridnest/
# DEBRIDNEST_S3_FORCE_PATH_STYLE=0
# DEBRIDNEST_S3_OFFLOAD_LOCAL=1
# Upload each file as soon as it finishes (minimizes peak disk use with offload local)
# DEBRIDNEST_S3_EARLY_OFFLOAD=1
# Preset: early offload + offload local (recommended for small VPS disks)
# DEBRIDNEST_S3_DIRECT=1
# Override torrent files directory (advanced: FUSE mount — not recommended)
# DEBRIDNEST_FILES_DIR=

# WebDAV library access (Infuse, Kodi, rclone) — see docs/webdav.md
# DEBRIDNEST_WEBDAV_ENABLED=1
# DEBRIDNEST_WEBDAV_USER=
# DEBRIDNEST_WEBDAV_PASSWORD=

# Prometheus metrics at GET /metrics (0 = disabled, 1 = enabled)
DEBRIDNEST_METRICS=0

# Stremio addon quality filters (docker compose --profile stremio)
PREFER_SDR=0
MAX_RESOLUTION=0
MAX_FILE_SIZE_GB=0
# Collapse duplicate Jackett results by info hash / similar title
DEDUPE_STREAMS=1
# When episode search returns few results, also search season packs
PREFER_SEASON_PACKS=1

# Real-Debrid API proxy for Torrentio (docker compose --profile torrentio)
# rd-proxy injects DEBRIDNEST_API_TOKEN and forwards /rest/1.0/* to DebridNest

# qBittorrent Web API for Sonarr/Radarr — see docs/arr-setup.md
# DEBRIDNEST_QBIT_USER=debridnest
# DEBRIDNEST_QBIT_PASSWORD=  # defaults to DEBRIDNEST_API_TOKEN

# Seeding after download completes — see docs/operations.md (0 disables each stop threshold)
# DEBRIDNEST_SEED_AFTER_COMPLETE=0
# DEBRIDNEST_SEED_RATIO=0
# DEBRIDNEST_SEED_MINUTES=0

# HLS transcode for incompatible audio (docker compose --profile transcode) — see docs/transcode.md
# DEBRIDNEST_TRANSCODE=0

# VPN sidecar (docker compose --profile vpn) — see docs/vpn.md
# VPN_SERVICE_PROVIDER=custom
# VPN_TYPE=openvpn
# OPENVPN_CONFIG_DIR=./deploy/vpn
# OPENVPN_USER=
# OPENVPN_PASSWORD=
