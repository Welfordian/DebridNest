# Home / LAN preset — DebridNest + Jackett + Stremio addon
# Usage:
#   cp deploy/env/home.env.example .env
#   docker compose --profile stremio up -d --build

DEBRIDNEST_API_TOKEN=change-me-to-a-long-random-string
DEBRIDNEST_PUBLIC_URL=http://localhost:8080
DEBRIDNEST_DOMAIN=localhost

# Jackett (included in --profile stremio)
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=
JACKETT_INDEXERS=1337x,knaben,limetorrents,magnetz,nyaasi,rutracker-ru,thepiratebay,therarbg,yts

# Stremio addon quality filters
PREFER_SDR=0
MAX_RESOLUTION=0
MAX_FILE_SIZE_GB=0
DEDUPE_STREAMS=1
PREFER_SEASON_PACKS=1

# Operations defaults
DEBRIDNEST_RETENTION_DAYS=30
DEBRIDNEST_DISK_QUOTA_GB=0
DEBRIDNEST_DOWNLOAD_RATE_LIMIT_MBPS=0
DEBRIDNEST_METRICS=0

# WebDAV library access (Infuse, Kodi, rclone)
DEBRIDNEST_WEBDAV_ENABLED=1

TZ=UTC
