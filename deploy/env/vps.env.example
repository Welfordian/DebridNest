# VPS / remote preset — TLS, tunnel, and optional VPN hints
# Pick the profiles you need:
#   docker compose --profile tls up -d
#   docker compose --profile tunnel up -d
#   docker compose --profile vpn up -d
#   docker compose --profile stremio up -d
#
# Combine profiles as needed, e.g.:
#   docker compose --profile tls --profile stremio up -d --build

DEBRIDNEST_API_TOKEN=change-me-to-a-long-random-string
DEBRIDNEST_PUBLIC_URL=https://debridnest.example.com
DEBRIDNEST_DOMAIN=debridnest.example.com

# Cloudflare Tunnel (docker compose --profile tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Jackett + Stremio (optional, same as home preset)
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=
JACKETT_INDEXERS=1337x,knaben,limetorrents,magnetz,nyaasi,rutracker-ru,thepiratebay,therarbg,yts

# Operations
DEBRIDNEST_RETENTION_DAYS=30
DEBRIDNEST_DISK_QUOTA_GB=500
DEBRIDNEST_DOWNLOAD_RATE_LIMIT_MBPS=0
DEBRIDNEST_METRICS=1

# qBittorrent API for Sonarr/Radarr — see docs/arr-setup.md
# DEBRIDNEST_QBIT_USER=debridnest
# DEBRIDNEST_QBIT_PASSWORD=

# VPN sidecar (docker compose --profile vpn) — see docs/vpn.md
# VPN_SERVICE_PROVIDER=custom
# VPN_TYPE=openvpn
# OPENVPN_CONFIG_DIR=./deploy/vpn
# OPENVPN_USER=
# OPENVPN_PASSWORD=
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=
# WIREGUARD_PUBLIC_KEY=
# WIREGUARD_ENDPOINT_IP=
# FIREWALL_OUTBOUND_SUBNETS=192.168.0.0/16,10.0.0.0/8

# Torrentio RD proxy (docker compose --profile torrentio) — see docs/torrentio-setup.md
# RD_PROXY_PORT=8444

TZ=UTC
